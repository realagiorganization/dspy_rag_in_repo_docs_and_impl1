# Copy this file to .env and replace placeholder values.
# The repository does not auto-load .env, so source it in your shell before use.

AZURE_OPENAI_CHAT_COMPLETIONS_URI=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<replace-with-azure-openai-key>
AZURE_OPENAI_DEPLOYMENT_NAME=<deployment-name>
AZURE_OPENAI_MODEL_NAME=<model-name>
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Mirror the Azure OpenAI values above if the same deployment is used for runtime inference.
AZURE_INFERENCE_ENDPOINT=https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview
AZURE_INFERENCE_CREDENTIAL=<replace-with-azure-openai-key>

# Optional for non-interactive GitHub CLI usage.
GH_TOKEN=<optional-github-token>
